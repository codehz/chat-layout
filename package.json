{
  "name": "chat-layout",
  "private": true,
  "module": "src/index.ts",
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "dependencies": {},
  "repository": {
    "url": "https://github.com/codehz/chat-layout.git"
  },
  "scripts": {
    "dist": "bun run scripts/dist.ts",
    "example": "cd example && bun run build.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml}": "prettier --write"
  },
  "version": "1.2.0-7"
